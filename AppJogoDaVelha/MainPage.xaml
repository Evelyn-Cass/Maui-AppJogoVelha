<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppJogoDaVelha.MainPage"
             Title="Jogo da Velha">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
            <GradientStop Color="#845ec2" Offset="0.3"/>
            <GradientStop Color="#4b4453" Offset="1.1"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <ContentPage.Resources>
        <Style TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="30"/>
            <Setter Property="TextColor" Value="#fef7ff"/>
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="BorderColor" Value="#fef7ff"/>
            <Setter Property="BorderWidth" Value="1.5"/>
            <Setter Property="FontAttributes" Value="Bold"/>
        </Style>
    </ContentPage.Resources>

    <ContentPage.Content>
        <Grid RowDefinitions="*,*,*" 
              ColumnDefinitions="*,*,*" 
              Margin="10" 
              x:Name="game" 
              ColumnSpacing="20" 
              RowSpacing="12">
            <Button x:Name="btn10" Grid.Row="0" Grid.Column="0" Clicked="ButtonClicked"/>
            <Button x:Name="btn11" Grid.Row="0" Grid.Column="1" Clicked="ButtonClicked"/>
            <Button x:Name="btn12" Grid.Row="0" Grid.Column="2" Clicked="ButtonClicked"/>

            <Button x:Name="btn20" Grid.Row="1" Grid.Column="0" Clicked="ButtonClicked"/>
            <Button x:Name="btn21" Grid.Row="1" Grid.Column="1" Clicked="ButtonClicked"/>
            <Button x:Name="btn22" Grid.Row="1" Grid.Column="2" Clicked="ButtonClicked"/>
            
            <Button x:Name="btn30" Grid.Row="2" Grid.Column="0" Clicked="ButtonClicked"/>
            <Button x:Name="btn31" Grid.Row="2" Grid.Column="1" Clicked="ButtonClicked"/>
            <Button x:Name="btn32" Grid.Row="2" Grid.Column="2" Clicked="ButtonClicked"/>

        </Grid>
    </ContentPage.Content>
</ContentPage>
